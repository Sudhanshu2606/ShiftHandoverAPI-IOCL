                        <div class="d-flex gap-2 ms-3 flex-wrap">
                            ${task.status !== "Completed" ? `
                            <div class="d-flex gap-1 align-items-center">
                                <select class="form-select form-select-sm mytask-status-select" data-task-id="${task.id}" style="width:140px;">
                                    <option value="Pending" ${task.status === "Pending" ? "selected" : ""}>📋 Pending</option>
                                    <option value="InProgress" ${task.status === "InProgress" ? "selected" : ""}>🔄 In Progress</option>
                                    <option value="Completed" ${task.status === "Completed" ? "selected" : ""}>✅ Completed</option>
                                </select>
                                <button class="btn btn-outline-primary btn-sm rounded-pill mytask-remarks-btn" data-task-id="${task.id}" title="Add Remarks"><i class="bi bi-chat-dots"></i></button>
                            </div>` : `<span class="badge bg-success p-2">✅ Completed</span>`}
                        </div>
                    </div>
                </div>`).join("");

            root.innerHTML = `
            <div style="background:#fff5eb;min-height:100vh;">
                <nav class="navbar shadow-sm" style="background: linear-gradient(90deg, #ff9800, #e65100);">
                    <div class="container-fluid px-4">
                        <div class="d-flex align-items-center gap-3">
                            <img src="iocl-logo.png" alt="IOCL" style="height:40px;background:white;padding:5px;border-radius:10px;" />
                            <div>
                                <span class="navbar-brand text-white fw-bold">My Tasks</span>
                                <small class="text-white-50 d-block">${esc(user?.name)} (${esc(user?.role)})</small>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button id="mt-dashboard-btn" class="btn btn-outline-light btn-sm rounded-pill">Dashboard</button>
                            ${user?.role === "Admin" ? `<button id="mt-reports-btn" class="btn btn-outline-light btn-sm rounded-pill"><i class="bi bi-file-earmark-bar-graph me-1"></i>Reports</button>` : ""}
                            <button id="mt-logout-btn" class="btn btn-outline-light btn-sm rounded-pill">Logout</button>
                        </div>
                    </div>
                </nav>

                <div class="container py-4">
                    <button id="mt-back-btn" class="btn btn-link text-decoration-none mb-3" style="color:#e65100;">← Back to Dashboard</button>

                    <div class="mb-4">
                        <h2 class="fw-bold" style="color:#e65100;">My Tasks</h2>
                        <p class="text-muted">Tasks assigned to you</p>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><h6 class="text-muted mb-1">Pending Tasks</h6><h2 class="fw-bold text-warning mb-0">${pendingTasks}</h2></div></div></div>
                        <div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><h6 class="text-muted mb-1">Completed Tasks</h6><h2 class="fw-bold text-success mb-0">${completedTasks}</h2></div></div></div>
                        <div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><h6 class="text-muted mb-1">High Priority</h6><h2 class="fw-bold text-danger mb-0">${highPriorityTasks}</h2></div></div></div>
                    </div>

                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white border-0 pt-4 pb-0"><h4 class="fw-bold" style="color:#e65100;">Tasks Assigned to Me</h4></div>
                        <div class="card-body p-4" id="mytasks-list">${tasksHtml}</div>
                    </div>

                    <div class="mt-4 p-3 bg-info bg-opacity-10 rounded-3 border border-info">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-info-circle-fill text-info"></i>
                            <small class="text-muted">
                                <strong>Note:</strong> You can only see tasks assigned to you.
                                ${user?.role === "Admin" ? " As Admin, you can see all tasks." : ""}
                                ${user?.role === "Supervisor" ? ` As Supervisor, you can see tasks assigned to your shift (${esc(user?.shiftAssigned)}).` : ""}
                            </small>
                        </div>
                    </div>
                </div>
            </div>`;

            document.getElementById("mt-dashboard-btn").addEventListener("click", () => navigateTo("#/dashboard"));
            document.getElementById("mt-logout-btn").addEventListener("click", goLogout);
            document.getElementById("mt-back-btn").addEventListener("click", () => navigateTo("#/dashboard"));
            
            const mtReportsBtn = document.getElementById("mt-reports-btn");
            if (mtReportsBtn) mtReportsBtn.addEventListener("click", () => navigateTo("#/reports"));

            document.querySelectorAll(".mytask-status-select").forEach((sel) => {
                sel.addEventListener("change", async () => {
                    const taskId = sel.dataset.taskId;
                    const newStatus = sel.value;
                    
                    const remarks = prompt(`Enter remarks for status change to "${newStatus}":`, "");
                    if (remarks === null) {
                        sel.value = sel.getAttribute('data-previous') || 'Pending';
                        return;
                    }

                    sel.disabled = true;
                    try {
                        await API.updateTaskStatus(taskId, { status: newStatus, remarks: remarks || "" });
                        await renderMyTasks(user);
                    } catch (err) {
                        console.error("Status update error:", err);
                        alert("❌ Failed to update status: " + (err.response?.data?.message || err.message));
                        sel.disabled = false;
                    }
                });
                sel.addEventListener('focus', function() {
                    this.setAttribute('data-previous', this.value);
                });
            });

            document.querySelectorAll(".mytask-remarks-btn").forEach((btn) => {
                btn.addEventListener("click", async () => {
                    const taskId = btn.dataset.taskId;
                    const task = tasks.find(t => t.id === parseInt(taskId));
                    const remarks = prompt(`Add remarks for task "${task?.title || taskId}":`, task?.remarks || "");
                    if (remarks === null) return;
                    
                    try {
                        await API.updateTask(taskId, {
                            ...task,
                            remarks: remarks || ""
                        });
                        await renderMyTasks(user);
                    } catch (err) {
                        alert("Failed to update remarks");
                    }
                });
            });
        }

        /* ============================================================
           PAGE: REPORTS (Admin Only)
           ============================================================ */
        let reportsState = {
            reports: [],
            filteredReports: [],
        };

        async function renderReports(user) {
            root.innerHTML = spinner();
            try {
                const reports = await API.getReports() || [];
                reportsState.reports = reports;
                reportsState.filteredReports = reports;
                drawReports(user);
            } catch (err) {
                console.error('Error loading reports:', err);
                root.innerHTML = `
                    <div class="min-vh-100 d-flex align-items-center justify-content-center" style="background:#fff5eb;">
                        <div class="text-center">
                            <i class="bi bi-exclamation-triangle fs-1 text-danger"></i>
                            <p class="mt-3 text-muted">Failed to load reports: ${esc(err.message)}</p>
                            <button class="btn btn-warning" onclick="renderReports(Auth.getUser())">Retry</button>
                        </div>
                    </div>
                `;
            }
        }

        function drawReports(user) {
            const reports = reportsState.filteredReports;
            const total = reports.length;
            const submitted = reports.filter(r => r.status === 'Submitted').length;
            const draft = reports.filter(r => r.status === 'Draft').length;
            let totalTasks = 0;
            reports.forEach(r => { if (r.tasks) totalTasks += r.tasks.length; });

            const units = [...new Set(reports.map(r => r.unit).filter(Boolean))];

            const html = `
                <nav class="navbar navbar-iocl shadow-sm px-4 py-2" style="background: linear-gradient(90deg, #ea580c, #dc2626);">
                    <div class="container-fluid">
                        <div class="d-flex align-items-center gap-3">
                            <img src="iocl-logo.png" alt="IOCL" style="height:40px;background:white;padding:5px;border-radius:10px;" 
                                 onerror="this.src='https://upload.wikimedia.org/wikipedia/commons/f/f8/Indian_Oil_Logo.svg'" />
                            <div>
                                <span class="navbar-brand text-white fw-bold">Admin Reports</span>
                                <small class="text-white-50 d-block">Shift Handover Management System</small>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <span class="text-white"><i class="bi bi-person-circle me-1"></i>${esc(user?.name || 'Admin')}</span>
                            <button id="reports-back-btn" class="btn btn-outline-light btn-sm rounded-pill">
                                <i class="bi bi-arrow-left me-1"></i>Dashboard
                            </button>
                            <button id="reports-logout-btn" class="btn btn-outline-light btn-sm rounded-pill">
                                <i class="bi bi-box-arrow-right me-1"></i>Logout
                            </button>
                        </div>
                    </div>
                </nav>

                <div class="container-fluid px-4 py-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h2 class="fw-bold text-iocl-orange mb-1" style="color:#e65100;"><i class="bi bi-file-earmark-bar-graph me-2"></i>Reports Dashboard</h2>
                            <p class="text-muted small">View and analyze all handover reports across refinery units</p>
                        </div>
                        <div class="d-flex gap-2">
                            <button id="export-csv-btn" class="btn btn-success btn-sm rounded-pill">
                                <i class="bi bi-download me-1"></i>Export CSV
                            </button>
                            <button id="print-reports-btn" class="btn btn-secondary btn-sm rounded-pill">
                                <i class="bi bi-printer me-1"></i>Print
                            </button>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-3">
                            <div class="stats-card d-flex justify-content-between align-items-center">
                                <div><h6 class="text-muted mb-1">Total Reports</h6><h3 class="fw-bold text-iocl-orange mb-0" style="color:#e65100;">${total}</h3></div>
                                <div class="bg-iocl-light rounded-circle p-3"><i class="bi bi-files fs-4 text-iocl-orange" style="color:#e65100;"></i></div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="stats-card d-flex justify-content-between align-items-center">
                                <div><h6 class="text-muted mb-1">Submitted</h6><h3 class="fw-bold text-success mb-0">${submitted}</h3></div>
                                <div class="bg-success bg-opacity-10 rounded-circle p-3"><i class="bi bi-check-circle fs-4 text-success"></i></div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="stats-card d-flex justify-content-between align-items-center">
                                <div><h6 class="text-muted mb-1">Draft</h6><h3 class="fw-bold text-warning mb-0">${draft}</h3></div>
                                <div class="bg-warning bg-opacity-10 rounded-circle p-3"><i class="bi bi-pencil-square fs-4 text-warning"></i></div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="stats-card d-flex justify-content-between align-items-center">
                                <div><h6 class="text-muted mb-1">Total Tasks</h6><h3 class="fw-bold text-primary mb-0">${totalTasks}</h3></div>
                                <div class="bg-primary bg-opacity-10 rounded-circle p-3"><i class="bi bi-list-check fs-4 text-primary"></i></div>
                            </div>
                        </div>
                    </div>

                    <div class="filter-section mb-4">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label class="fw-semibold small text-muted"><i class="bi bi-calendar-range me-1"></i>Date Range</label>
                                <div class="d-flex gap-2 align-items-center">
                                    <input type="date" id="report-date-from" class="form-control form-control-sm" style="width:140px;" />
                                    <span class="text-muted">to</span>
                                    <input type="date" id="report-date-to" class="form-control form-control-sm" style="width:140px;" />
                                </div>
                            </div>
                            <div class="col-md-3">
                                <label class="fw-semibold small text-muted"><i class="bi bi-building me-1"></i>Unit</label>
                                <select id="report-unit-filter" class="form-select form-select-sm">
                                    <option value="all">All Units</option>
                                    ${units.map(u => `<option value="${esc(u)}">${esc(getUnitName(u))}</option>`).join('')}
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="fw-semibold small text-muted"><i class="bi bi-shift me-1"></i>Shift</label>
                                <select id="report-shift-filter" class="form-select form-select-sm">
                                    <option value="all">All Shifts</option>
                                    <option value="Morning">Morning</option>
                                    <option value="Evening">Evening</option>
                                    <option value="Night">Night</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="fw-semibold small text-muted"><i class="bi bi-search me-1"></i>Search</label>
                                <input type="text" id="report-search" class="form-control form-control-sm" placeholder="Search by summary, unit..." />
                            </div>
                        </div>
                        <div class="mt-3 d-flex gap-2">
                            <button id="report-apply-filters" class="btn btn-sm btn-warning" style="background:linear-gradient(90deg,#ff9800,#e65100);color:white;border:none;border-radius:50px;padding:8px 24px;font-weight:600;">Apply Filters</button>
                            <button id="report-clear-filters" class="btn btn-sm btn-outline-secondary">Clear</button>
                        </div>
                    </div>

                    ${reports.length === 0 ? `
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                            <p>No reports found matching the filters.</p>
                        </div>
                    ` : reports.map(report => {
                        const tasks = report.tasks || [];
                        const creatorName = report.creator?.name || 'Unknown';
                        const statusBadge = report.status === 'Submitted' ? 
                            '<span class="badge status-badge-submitted">✅ Submitted</span>' : 
                            '<span class="badge status-badge-draft">📝 Draft</span>';
                        const shiftBadge = report.shiftName === 'Morning' ? 
                            '<span class="badge bg-warning text-dark">Morning</span>' :
                            report.shiftName === 'Evening' ?
                            '<span class="badge bg-info text-dark">Evening</span>' :
                            '<span class="badge bg-secondary text-white">Night</span>';

                        return `
                        <div class="report-detail-card">
                            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                                <div>
                                    <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                                        <span class="fw-bold text-iocl-orange" style="color:#e65100;">#${report.id}</span>
                                        ${statusBadge} ${shiftBadge}
                                        <span class="badge bg-light text-dark">${esc(getUnitName(report.unit))}</span>
                                    </div>
                                    <div class="mb-2">
                                        <p class="mb-1">${esc(report.summary || 'No summary')}</p>
                                        <div class="d-flex flex-wrap gap-3 small text-muted">
                                            <span><i class="bi bi-calendar3 me-1"></i>${formatDate(report.date)} at ${formatTime(report.date)}</span>
                                            <span><i class="bi bi-person me-1"></i>Created by: ${esc(creatorName)}</span>
                                            <span><i class="bi bi-list-check me-1"></i>${tasks.length} tasks</span>
                                        </div>
                                    </div>
                                    ${tasks.length > 0 ? `
                                        <div class="mt-2">
                                            <strong class="small text-muted">Tasks:</strong>
                                            <div class="d-flex flex-wrap gap-2 mt-1">
                                                ${tasks.slice(0, 3).map(task => `
                                                    <span class="badge bg-light text-dark border">
                                                        ${esc(task.title)}
                                                        ${task.priority ? `<span class="badge ${task.priority === 'High' ? 'bg-danger' : task.priority === 'Medium' ? 'bg-warning' : 'bg-success'} text-white">${esc(task.priority)}</span>` : ''}
                                                        ${task.status ? `<span class="badge ${task.status === 'Completed' ? 'bg-success' : task.status === 'InProgress' ? 'bg-primary' : 'bg-secondary'} text-white">${esc(task.status)}</span>` : ''}
                                                        ${task.remarks ? `<i class="bi bi-chat-dots" title="${esc(task.remarks)}"></i>` : ''}
                                                    </span>
                                                `).join('')}
                                                ${tasks.length > 3 ? `<span class="badge bg-light text-dark">+${tasks.length - 3} more</span>` : ''}
                                            </div>
                                        </div>
                                    ` : ''}
                                </div>
                                <div class="d-flex gap-2 flex-shrink-0">
                                    <button class="btn btn-sm btn-outline-info rounded-pill view-report-btn" data-id="${report.id}">
                                        <i class="bi bi-eye"></i> View
                                    </button>
                                </div>
                            </div>
                        </div>`;
                    }).join('')}

                    <footer class="mt-5 pt-3 border-top text-center" style="border-color:#ffe0b2;">
                        <p class="small text-muted mb-0">© ${new Date().getFullYear()} Indian Oil Corporation Limited | Panipat Refinery</p>
                    </footer>
                </div>
            `;

            root.innerHTML = html;

            // Event bindings
            document.getElementById("reports-back-btn").addEventListener("click", () => navigateTo("#/dashboard"));
            document.getElementById("reports-logout-btn").addEventListener("click", goLogout);

            document.querySelectorAll(".view-report-btn").forEach(btn => {
                btn.addEventListener("click", function() {
                    navigateTo(`#/handover/${this.dataset.id}`);
                });
            });

            document.getElementById("report-apply-filters").addEventListener("click", applyReportFilters);
            document.getElementById("report-clear-filters").addEventListener("click", () => {
                document.getElementById("report-date-from").value = '';
                document.getElementById("report-date-to").value = '';
                document.getElementById("report-unit-filter").value = 'all';
                document.getElementById("report-shift-filter").value = 'all';
                document.getElementById("report-search").value = '';
                applyReportFilters();
            });

            document.getElementById("report-search").addEventListener("keydown", (e) => {
                if (e.key === 'Enter') applyReportFilters();
            });

            document.getElementById("export-csv-btn").addEventListener("click", () => {
                const reports = reportsState.filteredReports;
                if (reports.length === 0) { alert('No reports to export.'); return; }
                let csv = 'ID,Date,Shift,Unit,Summary,Status,Creator,Tasks\n';
                reports.forEach(r => {
                    csv += [
                        r.id,
                        new Date(r.date).toLocaleDateString('en-IN'),
                        r.shiftName || '',
                        getUnitName(r.unit),
                        (r.summary || '').replace(/,/g, ';'),
                        r.status || '',
                        r.creator?.name || '',
                        (r.tasks?.length || 0)
                    ].join(',') + '\n';
                });
                const blob = new Blob([csv], { type: 'text/csv' });
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = `shift_reports_${new Date().toISOString().split('T')[0]}.csv`;
                a.click();
                URL.revokeObjectURL(url);
            });

            document.getElementById("print-reports-btn").addEventListener("click", () => window.print());
        }

        function applyReportFilters() {
            const from = document.getElementById("report-date-from").value;
            const to = document.getElementById("report-date-to").value;
            const unit = document.getElementById("report-unit-filter").value;
            const shift = document.getElementById("report-shift-filter").value;
            const search = document.getElementById("report-search").value.toLowerCase();

            reportsState.filteredReports = reportsState.reports.filter(report => {
                if (from) {
                    const reportDate = new Date(report.date);
                    const fromDate = new Date(from);
                    if (reportDate < fromDate) return false;
                }
                if (to) {
                    const reportDate = new Date(report.date);
                    const toDate = new Date(to);
                    toDate.setHours(23, 59, 59);
                    if (reportDate > toDate) return false;
                }
                if (unit !== 'all' && report.unit !== unit) return false;
                if (shift !== 'all' && report.shiftName !== shift) return false;
                if (search) {
                    const summary = (report.summary || '').toLowerCase();
                    const unitName = getUnitName(report.unit).toLowerCase();
                    const creator = (report.creator?.name || '').toLowerCase();
                    if (!summary.includes(search) && !unitName.includes(search) && !creator.includes(search)) {
                        return false;
                    }
                }
                return true;
            });

            drawReports(Auth.getUser());
        }

        console.log("✅ Index.cshtml loaded successfully!");
        console.log("All features are ready!");
    </script>
</body>
</html>