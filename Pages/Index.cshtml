            const close = () => { slot.innerHTML = ""; };
            document.getElementById("close-create-modal").addEventListener("click", close);
            document.getElementById("cancel-create-modal").addEventListener("click", close);

            document.getElementById("create-handover-form").addEventListener("submit", async (e) => {
                e.preventDefault();
                const submitBtn = document.getElementById("create-handover-submit");
                submitBtn.disabled = true;
                submitBtn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span>Creating...`;

                const unitId = document.getElementById("ch-unit").value;
                const unitData = refineryUnits.find((u) => u.id === unitId);
                const status = document.querySelector('input[name="ch-status"]:checked').value;

                try {
                    await API.createHandover({
                        shiftName: document.getElementById("ch-shift").value,
                        summary: document.getElementById("ch-summary").value,
