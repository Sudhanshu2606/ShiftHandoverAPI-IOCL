@page
@{
    Layout = null;
    ViewData["Title"] = "IOCL Panipat Refinery - Shift Handover Management System";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#000000" />
    <meta name="description" content="IOCL Panipat Refinery - Shift Handover Management System" />
    <title>IOCL Panipat Refinery - Shift Handover Management System</title>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <style>
        body {
            font-family: "Inter", sans-serif;
        }
        .text-white-75 {
            color: rgba(255, 255, 255, 0.85);
        }
        .clickable {
            cursor: pointer;
        }
        .app-bg {
            background: #fff5eb;
            min-height: 100vh;
        }
        .task-remarks-bubble {
            background: #f0f7ff;
            border-radius: 8px;
            padding: 4px 10px;
            font-size: 0.85rem;
            border-left: 3px solid #4a90d9;
            margin-top: 4px;
            color: #333;
        }
        .status-badge-submitted {
            background: #d4edda;
            color: #155724;
        }
        .status-badge-draft {
            background: #fff3cd;
            color: #856404;
        }
        .btn-iocl-primary {
            background: linear-gradient(90deg, #ff9800, #e65100);
            color: white;
            border: none;
        }
        .btn-iocl-primary:hover {
            opacity: 0.9;
            color: white;
        }
        .report-card-hover:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 16px rgba(0,0,0,0.1) !important;
            transition: all 0.2s ease;
        }
        .navbar-iocl {
            background: linear-gradient(90deg, #ea580c, #dc2626);
        }
        .text-iocl-orange {
            color: #e65100;
        }
        .bg-iocl-light {
            background: #fff5eb;
        }
        .filter-section {
            background: white;
            border-radius: 12px;
            padding: 16px 20px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        }
        .stats-card {
            background: white;
            border-radius: 12px;
            padding: 16px 20px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        }
        .report-detail-card {
            border-left: 4px solid #ff9800;
            border-radius: 8px;
            background: white;
            padding: 16px 20px;
            margin-bottom: 12px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
        }
    </style>
</head>
<body>
    <div id="app">
        <div class="min-vh-100 d-flex align-items-center justify-content-center" style="background:#fff5eb;">
            <div class="text-center">
                <div class="spinner-border text-warning" role="status"></div>
                <p class="mt-3 text-muted">Loading Shift Handover System...</p>
            </div>
        </div>
    </div>

    <script>
        /* ============================================================
           CONFIGURATION
           ============================================================ */
        const API_BASE_URL = "/api";

        /* ============================================================
           AUTH HELPERS
           ============================================================ */
        const Auth = {
            getUser() {
                const saved = localStorage.getItem("user");
                return saved ? JSON.parse(saved) : null;
            },
            getToken() {
                return localStorage.getItem("token");
            },
            login(userData, token) {
                localStorage.setItem("token", token);
                localStorage.setItem("user", JSON.stringify(userData));
            },
            logout() {
                localStorage.clear();
            },
        };

        /* ============================================================
           API LAYER
           ============================================================ */
        async function apiRequest(method, path, body) {
            const token = localStorage.getItem("token");
            const headers = { "Content-Type": "application/json" };
            if (token) headers["Authorization"] = "Bearer " + token;

            const res = await fetch(API_BASE_URL + path, {
                method,
                headers,
                body: body !== undefined ? JSON.stringify(body) : undefined,
            });

            if (!res.ok) {
                let message = res.statusText;
                try {
                    const errData = await res.json();
                    message = errData.message || message;
                } catch (e) {}
                const err = new Error(message);
                err.response = { data: { message } };
                throw err;
            }

            const text = await res.text();
            return text ? JSON.parse(text) : null;
        }

        const API = {
            login: (data) => apiRequest("POST", "/Auth/login", data),
            register: (data) => apiRequest("POST", "/Auth/register", data),
            getUsers: () => apiRequest("GET", "/User"),
            getUsersByShift: (shift) => apiRequest("GET", `/User/shift/${shift}`),
            getUsersByRole: (role) => apiRequest("GET", `/User/role/${role}`),
            getHandovers: () => apiRequest("GET", "/Handover"),
            getHandover: (id) => apiRequest("GET", `/Handover/${id}`),
            createHandover: (data) => apiRequest("POST", "/Handover", data),
            updateHandover: (id, data) => apiRequest("PUT", `/Handover/${id}`, data),
            deleteHandover: (id) => apiRequest("DELETE", `/Handover/${id}`),
            getTasksByHandover: (handoverId) => apiRequest("GET", `/Task/handover/${handoverId}`),
            getAllTasks: () => apiRequest("GET", "/Task/all"),
            getMyTasks: () => apiRequest("GET", "/Task/my-tasks"),
            getTasksAssignedToMe: () => apiRequest("GET", "/Task/assigned-to-me"),
            getTasksByShift: (shift) => apiRequest("GET", `/Task/shift/${shift}`),
            getTasksCreatedByMe: (userId) => apiRequest("GET", `/Task/created-by/${userId}`),
            createTask: (data) => apiRequest("POST", "/Task", data),
            updateTask: (id, data) => apiRequest("PUT", `/Task/${id}`, data),
            updateTaskStatus: (id, data) => apiRequest("PUT", `/Task/${id}/status`, data),
            reassignTask: (id, newAssignedTo) => apiRequest("PUT", `/Task/${id}/reassign`, newAssignedTo),
            deleteTask: (id) => apiRequest("DELETE", `/Task/${id}`),
            getIssuesByHandover: (handoverId) => apiRequest("GET", `/Issue/handover/${handoverId}`),
            createIssue: (data) => apiRequest("POST", "/Issue", data),
            updateIssue: (id, data) => apiRequest("PUT", `/Issue/${id}`, data),
            deleteIssue: (id) => apiRequest("DELETE", `/Issue/${id}`),
            // Admin Reports
            getReports: () => apiRequest("GET", "/Handover/reports"),
            getReportsByDate: (date) => apiRequest("GET", `/Handover/reports/date/${date}`),
            getReportsByDateRange: (from, to) => apiRequest("GET", `/Handover/reports/range?from=${from}&to=${to}`),
        };

        /* ============================================================
           CONSTANTS
           ============================================================ */
        const refineryUnits = [
            { id: "cdu", name: "CDU/VDU - Crude Distillation Unit", group: "Primary Processing", capacity: "7.5 MMTPA" },
            { id: "rfccu", name: "RFCCU - Resid Fluidised Catalytic Cracking", group: "Secondary Processing", capacity: "0.85 MMTPA" },
            { id: "dcu", name: "DCU - Delayed Coker Unit", group: "Secondary Processing", capacity: "3.0 MMTPA" },
            { id: "ohcu", name: "OHCU - Once Through Hydrocracker", group: "Secondary Processing", capacity: "1.9 MMTPA" },
            { id: "hcu", name: "HCU - Hydrocracker Unit", group: "Secondary Processing", capacity: "1.8 MMTPA" },
            { id: "dhds", name: "DHDS - Diesel Hydro Desulphurisation", group: "Secondary Processing", capacity: "0.77 MMTPA" },
            { id: "ncu", name: "NCU - Naphtha Cracker Unit", group: "Petrochemical", capacity: "800k TPA" },
            { id: "pp", name: "PP - Polypropylene Unit", group: "Petrochemical", capacity: "600k TPA" },
            { id: "hdpe", name: "HDPE - High Density Polyethylene", group: "Petrochemical", capacity: "300k TPA" },
            { id: "tankfarm", name: "Tank Farms - OM&S", group: "Offsites", capacity: "Large" },
            { id: "etp", name: "ETP - Effluent Treatment Plant", group: "Environment", capacity: "Multiple" },
            { id: "power", name: "Power Plant - 239 MW", group: "Utilities", capacity: "239 MW" },
        ];
        const unitGroups = ["All", "Primary Processing", "Secondary Processing", "Petrochemical", "Offsites", "Environment", "Utilities"];

        /* ============================================================
           UTILITY FUNCTIONS
           ============================================================ */
        function esc(str) {
            if (str === null || str === undefined) return "";
            return String(str).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
        }

        function priorityColor(p) {
            if (p === "High") return "bg-danger text-white";
            if (p === "Medium") return "bg-warning text-dark";
            return "bg-success text-white";
        }

        function statusColor(s) {
            if (s === "Completed") return "bg-success text-white";
            if (s === "InProgress") return "bg-primary text-white";
            return "bg-secondary text-white";
        }

        function spinner(extraClass) {
            return `<div class="min-vh-100 d-flex align-items-center justify-content-center ${extraClass || ""}" style="background:#fff5eb">
                <div class="spinner-border text-warning" role="status"></div>
            </div>`;
        }

        function navigateTo(hash) {
            window.location.hash = hash;
        }

        function goLogout() {
            Auth.logout();
            navigateTo("#/");
        }

        function formatDate(dateStr) {
            if (!dateStr) return '-';
            const d = new Date(dateStr);
            return d.toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });
        }

        function formatTime(dateStr) {
            if (!dateStr) return '';
            const d = new Date(dateStr);
            return d.toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' });
        }

        function getUnitName(unitId) {
            const unit = refineryUnits.find(u => u.id === unitId);
            return unit ? unit.name : unitId || 'N/A';
        }

        const root = document.getElementById("app");

        /* ============================================================
           ROUTER
           ============================================================ */
        function parseHash() {
            const hash = window.location.hash || "#/";
            const path = hash.replace(/^#/, "") || "/";
            const parts = path.split("/").filter(Boolean);
            return parts;
        }

        async function router() {
            const user = Auth.getUser();
            const parts = parseHash();

            const isProtected = parts.length > 0 && parts[0] !== '';
            if (isProtected && !user) {
                navigateTo("#/");
                return;
            }

            if (parts.length === 0 || parts[0] === '') {
                renderLogin();
            } else if (parts[0] === "dashboard") {
                renderDashboard(user);
            } else if (parts[0] === "handover" && parts[1] === "edit" && parts[2]) {
                if (!(user.role === "Admin" || user.role === "Supervisor")) {
                    navigateTo("#/dashboard");
                    return;
                }
                renderEditHandover(user, parts[2]);
            } else if (parts[0] === "handover" && parts[1]) {
                renderHandoverDetails(user, parts[1]);
            } else if (parts[0] === "add-employee") {
                if (user.role !== "Admin") {
                    navigateTo("#/dashboard");
                    return;
                }
                renderAddEmployee(user);
            } else if (parts[0] === "my-tasks") {
                renderMyTasks(user);
            } else if (parts[0] === "reports") {
                if (user.role !== "Admin") {
                    navigateTo("#/dashboard");
                    return;
                }
                renderReports(user);
            } else {
                renderLogin();
            }
        }

        window.addEventListener("hashchange", router);
        window.addEventListener("DOMContentLoaded", router);

        /* ============================================================
           PAGE: LOGIN
           ============================================================ */
        function renderLogin() {
            root.innerHTML = `
            <div class="min-vh-100 d-flex align-items-center justify-content-center p-3" style="background: linear-gradient(135deg, #fff5eb 0%, #ffe0b2 100%);">
                <div class="container">
                    <div class="row justify-content-center">
                        <div class="col-md-5 col-lg-4">
                            <div class="card shadow-lg border-0 rounded-4 overflow-hidden" style="background:white;">
                                <div class="d-flex flex-column align-items-center justify-content-center pt-4 pb-1">
                                    <img id="login-logo" src="iocl-logo.png" alt="Indian Oil Corporation Limited" class="img-fluid" style="height:70px;width:auto;object-fit:contain;" />
                                    <h2 class="fw-bold mt-2 mb-0" style="color:#e65100;">Shift Handover</h2>
                                    <p class="text-muted small mb-1">Management System</p>
                                    <div class="d-flex justify-content-center gap-2 mb-1">
                                        <div style="width:35px;height:2px;background:#ff9800;border-radius:2px;"></div>
                                        <div style="width:35px;height:2px;background:#e65100;border-radius:2px;"></div>
                                        <div style="width:35px;height:2px;background:#ff9800;border-radius:2px;"></div>
                                    </div>
                                    <p class="small text-muted">IOCL Panipat Refinery</p>
                                </div>
                                <div class="card-body p-4 pt-0">
                                    <div id="login-error"></div>
                                    <form id="login-form">
                                        <div class="mb-3">
                                            <label class="form-label fw-semibold small" style="color:#e65100;">Email Address</label>
                                            <div class="input-group">
                                                <span class="input-group-text bg-white border-end-0" style="border-color:#ffe0b2;">
                                                    <i class="bi bi-envelope" style="color:#ff9800;"></i>
                                                </span>
                                                <input type="email" id="login-email" class="form-control border-start-0 ps-0" style="border-color:#ffe0b2;" placeholder="Enter your email" required />
                                            </div>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label fw-semibold small" style="color:#e65100;">Password</label>
                                            <div class="input-group">
                                                <span class="input-group-text bg-white border-end-0" style="border-color:#ffe0b2;">
                                                    <i class="bi bi-lock" style="color:#ff9800;"></i>
                                                </span>
                                                <input type="password" id="login-password" class="form-control border-start-0 ps-0" style="border-color:#ffe0b2;" placeholder="Enter your password" required />
                                            </div>
                                        </div>
                                        <button type="submit" id="login-submit-btn" class="btn w-100 py-2 fw-bold text-white border-0 mb-2" style="background: linear-gradient(90deg, #ff9800, #e65100); border-radius:10px;">
                                            <i class="bi bi-box-arrow-in-right me-2"></i>Login
                                        </button>
                                    </form>
                                    <div class="d-flex align-items-center justify-content-center gap-2 my-2">
                                        <div style="flex:1;height:1px;background:#ffe0b2;"></div>
                                        <i class="bi bi-shield-check" style="color:#ff9800;font-size:14px;"></i>
                                        <div style="flex:1;height:1px;background:#ffe0b2;"></div>
                                    </div>
                                    <div class="text-center">
                                        <p class="small text-muted mb-0">Authorized Personnel Only</p>
                                    </div>
                                </div>
                                <div class="text-center pb-3">
                                    <small class="text-muted" style="font-size:11px;">© 2024 Indian Oil Corporation Limited</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>`;

            document.getElementById("login-logo").addEventListener("error", function() {
                this.onerror = null;
                this.src = "https://upload.wikimedia.org/wikipedia/commons/f/f8/Indian_Oil_Logo.svg";
            });

            document.getElementById("login-form").addEventListener("submit", async (e) => {
                e.preventDefault();
                const email = document.getElementById("login-email").value;
                const password = document.getElementById("login-password").value;
                const errorBox = document.getElementById("login-error");
                const submitBtn = document.getElementById("login-submit-btn");
                errorBox.innerHTML = "";
                submitBtn.disabled = true;
                submitBtn.innerHTML = `<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Logging in...`;

                try {
                    const res = await API.login({ email, password });
                    Auth.login({
                        id: res.id,
                        name: res.name,
                        role: res.role,
                        department: res.department,
                        shiftAssigned: res.shiftAssigned,
                    }, res.token);
                    navigateTo("#/dashboard");
                } catch (err) {
                    errorBox.innerHTML = `<div class="alert alert-danger py-2 text-center small mb-3" role="alert" style="background:#ffebee;border-color:#ffcdd2;color:#c62828;">
                        <i class="bi bi-exclamation-triangle me-2"></i>Invalid email or password!
                    </div>`;
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = `<i class="bi bi-box-arrow-in-right me-2"></i>Login`;
                }
            });
        }

        /* ============================================================
           PAGE: DASHBOARD
           ============================================================ */
        let dashboardState = {
            handovers: [],
            searchTerm: "",
            selectedUnit: "all",
            selectedGroup: "All",
        };

        async function renderDashboard(user) {
            root.innerHTML = spinner();
            let handovers = [];
            try {
                handovers = (await API.getHandovers()) || [];
            } catch (err) {
                console.error("Error:", err);
                handovers = [];
            }
            dashboardState.handovers = handovers;
            dashboardState.searchTerm = "";
            dashboardState.selectedUnit = "all";
            dashboardState.selectedGroup = "All";
            drawDashboard(user);
        }

        function getFilteredHandovers(user) {
            let filtered = dashboardState.handovers;
            if (user?.role === "Supervisor") {
                filtered = filtered.filter(
                    (h) => h.shiftName === user?.shiftAssigned || h.createdBy === user?.id
                );
            }
            if (dashboardState.selectedGroup !== "All") {
                const groupUnitIds = refineryUnits
                    .filter((u) => u.group === dashboardState.selectedGroup)
                    .map((u) => u.id);
                filtered = filtered.filter((h) => groupUnitIds.includes(h.unit));
            }
            if (dashboardState.selectedUnit !== "all") {
                filtered = filtered.filter(
                    (h) => h.unit === dashboardState.selectedUnit
                );
            }
            const term = dashboardState.searchTerm.toLowerCase();
            filtered = filtered.filter((h) => {
                return (
                    (h.summary || "").toLowerCase().includes(term) ||
                    (h.shiftName || "").toLowerCase().includes(term) ||
                    (h.unitName || "").toLowerCase().includes(term)
                );
            });
            return filtered;
        }

        function drawDashboard(user) {
            const handovers = dashboardState.handovers;
            const visibleHandovers = getFilteredHandovers(user);
            const draftCount = visibleHandovers.filter(
                (h) => h.status === "Draft"
            ).length;
            const submittedCount = visibleHandovers.filter(
                (h) => h.status === "Submitted"
            ).length;

            const unitCount = {};
            handovers.forEach((h) => {
                if (h.unit) unitCount[h.unit] = (unitCount[h.unit] || 0) + 1;
            });

            const groupCount = {};
            handovers.forEach((h) => {
                const unit = refineryUnits.find((u) => u.id === h.unit);
                if (unit && unit.group)
                    groupCount[unit.group] = (groupCount[unit.group] || 0) + 1;
            });

            const hour = new Date().getHours();
            const greeting = hour < 12 ? "Morning" : hour < 18 ? "Afternoon" : "Evening";

            const unitFilterHtml = user?.role === "Admin" ? `
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <h6 class="fw-bold mb-3" style="color:#e65100;">Filter by Refinery Unit</h6>
                    <div class="d-flex flex-wrap gap-2 mb-3 pb-2 border-bottom" id="group-filter-row">
                        ${unitGroups.map((group) => {
                            const active = dashboardState.selectedGroup === group;
                            let badge = "";
                            if (group !== "All" && groupCount[group] > 0)
                                badge = `<span class="badge bg-secondary ms-1">${groupCount[group]}</span>`;
                            if (group === "All" && handovers.length > 0)
                                badge = `<span class="badge bg-secondary ms-1">${handovers.length}</span>`;
                            return `<button data-group="${esc(group)}" class="btn btn-sm rounded-pill group-filter-btn ${active ? "btn-warning" : "btn-outline-secondary"}">${esc(group)}${badge}</button>`;
                        }).join("")}
                    </div>
                    <div class="d-flex flex-wrap gap-2" id="unit-filter-row">
                        ${refineryUnits.filter(u => dashboardState.selectedGroup === "All" || u.group === dashboardState.selectedGroup)
                            .map((unit) => {
                                const active = dashboardState.selectedUnit === unit.id;
                                const badge = unitCount[unit.id] > 0 ? `<span class="badge bg-secondary ms-1">${unitCount[unit.id]}</span>` : "";
                                return `<button data-unit="${esc(unit.id)}" class="btn btn-sm rounded-pill unit-filter-btn ${active ? "btn-warning" : "btn-outline-secondary"}">${esc(unit.name)}${badge}</button>`;
                            }).join("")}
                    </div>
                </div>
            </div>` : "";

            const rowsHtml = visibleHandovers.length === 0 ?
                `<tr><td colspan="8" class="text-center py-5 text-muted"><i class="bi bi-inbox fs-1 d-block mb-2"></i>No handover reports found.</td></tr>` :
                visibleHandovers.map((handover) => {
                    const date = new Date(handover.date);
                    const shiftBadge = handover.shiftName === "Morning" ? "bg-warning" :
                        handover.shiftName === "Evening" ? "bg-info" : "bg-secondary";
                    const canEditDelete = user?.role === "Admin" ||
                        (user?.role === "Supervisor" && handover.createdBy === user?.id);
                    return `<tr>
                        <td class="px-4 py-3">${date.toLocaleDateString()}<br><small class="text-muted">${date.toLocaleTimeString()}</small></td>
                        <td class="px-4 py-3"><span class="badge ${shiftBadge} rounded-pill">${esc(handover.shiftName)}</span></td>
                        <td class="px-4 py-3"><span class="badge bg-light text-dark rounded-pill">${esc(handover.unitName || handover.unit || "-")}</span></td>
                        <td class="px-4 py-3">${esc((handover.summary || "").substring(0, 60))}...</td>
                        <td class="px-4 py-3">${(handover.tasks && handover.tasks.length) || 0}</td>
                        <td class="px-4 py-3">${(handover.issues && handover.issues.length) || 0}</td>
                        <td class="px-4 py-3"><span class="badge ${handover.status === "Submitted" ? "bg-success" : "bg-warning"} rounded-pill">${esc(handover.status)}</span></td>
                        <td class="px-4 py-3">
                            <div class="btn-group btn-group-sm">
                                <button data-action="view" data-id="${handover.id}" class="btn btn-outline-info btn-sm rounded-pill me-1" title="View"><i class="bi bi-eye"></i></button>
                                ${canEditDelete ? `
                                <button data-action="edit" data-id="${handover.id}" class="btn btn-outline-warning btn-sm rounded-pill me-1" title="Edit"><i class="bi bi-pencil"></i></button>
                                <button data-action="delete" data-id="${handover.id}" class="btn btn-outline-danger btn-sm rounded-pill" title="Delete"><i class="bi bi-trash"></i></button>` : ""}
                            </div>
                        </td>
                    </tr>`;
                }).join("");

            root.innerHTML = `
            <div style="background:#fff5eb;min-height:100vh;">
                <div class="text-white px-4 py-3 shadow-sm d-flex justify-content-between align-items-center" style="background: linear-gradient(90deg, #ea580c, #dc2626);">
                    <div class="d-flex align-items-center gap-2">
                        <img src="iocl-logo.png" alt="IOCL" style="height:40px;background:white;padding:5px;border-radius:10px;" />
                        <div>
                            <span class="fw-bold">Indian Oil Panipat Refinery</span>
                            <small class="d-block text-white-50">Shift Handover Management System</small>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <div class="text-end">
                            <div class="fw-semibold small">${esc(user?.name)}</div>
                            <small class="text-white-50">${esc(user?.role)} | ${esc(user?.shiftAssigned || "General")}</small>
                        </div>
