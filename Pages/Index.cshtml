        /* ============================================================
           DRAW TASK LIST (with Remarks)
           ============================================================ */
        async function drawTaskList(handoverId, user) {
            const slot = document.getElementById("task-list-slot");
            slot.innerHTML = `<div class="text-center py-4">Loading tasks...</div>`;
            let tasks = [];
            try {
                tasks = (await API.getTasksByHandover(handoverId)) || [];
            } catch (err) {
                console.error("Error:", err);
                tasks = [];
            }

            const canUpdate = user?.role === "Admin" || user?.role === "Supervisor" || user?.role === "Operator";
            const canDelete = user?.role === "Admin";

            if (tasks.length === 0) {
                slot.innerHTML = `<div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                    <p>No tasks added yet.</p>
                    ${user?.role === "Admin" || user?.role === "Supervisor" ? `<p class="small">Click "Add Task" to create one.</p>` : ""}
                </div>`;
                return;
            }

            slot.innerHTML = tasks.map((task) => `
            <div class="border rounded-3 p-3 mb-3 shadow-sm">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
                            <h5 class="fw-bold mb-0">${esc(task.title)}</h5>
                            <span class="badge ${priorityColor(task.priority)}">${esc(task.priority)}</span>
                            <span class="badge ${statusColor(task.status)}">${task.status === "InProgress" ? "In Progress" : esc(task.status)}</span>
                        </div>
                        ${task.description ? `<p class="text-muted mb-2">${esc(task.description)}</p>` : ""}
                        ${task.assignedUser ? `<p class="small text-muted mb-1"><i class="bi bi-person me-1"></i>Assigned to: ${esc(task.assignedUser.name)}</p>` : ""}
                        ${task.dueDate ? `<p class="small text-muted"><i class="bi bi-calendar me-1"></i>Due: ${new Date(task.dueDate).toLocaleDateString()}</p>` : ""}
                        ${task.remarks ? `<div class="task-remarks-bubble"><i class="bi bi-chat-dots me-1"></i>${esc(task.remarks)}</div>` : ""}
                    </div>
                    <div class="d-flex gap-2 ms-3 flex-wrap">
                        ${canUpdate ? `
                        <div class="d-flex gap-1 align-items-center">
                            <select class="form-select form-select-sm task-status-select" data-task-id="${task.id}" style="width:130px;">
                                <option value="Pending" ${task.status === "Pending" ? "selected" : ""}>📋 Pending</option>
                                <option value="InProgress" ${task.status === "InProgress" ? "selected" : ""}>🔄 In Progress</option>
                                <option value="Completed" ${task.status === "Completed" ? "selected" : ""}>✅ Completed</option>
                            </select>
                            <button class="btn btn-outline-primary btn-sm rounded-pill task-remarks-btn" data-task-id="${task.id}" title="Add Remarks"><i class="bi bi-chat-dots"></i></button>
                        </div>` : ""}
                        ${canDelete ? `<button class="btn btn-outline-danger btn-sm rounded-pill task-delete-btn" data-task-id="${task.id}"><i class="bi bi-trash"></i></button>` : ""}
                    </div>
                </div>
            </div>`).join("");

            // Status change handler with remarks
            slot.querySelectorAll(".task-status-select").forEach((sel) => {
                sel.addEventListener("change", async () => {
                    const taskId = sel.dataset.taskId;
                    const newStatus = sel.value;
                    
                    const remarks = prompt(`Enter remarks for status change to "${newStatus}":`, "");
                    if (remarks === null) {
                        sel.value = sel.getAttribute('data-previous') || 'Pending';
                        return;
                    }

                    sel.disabled = true;
                    try {
                        await API.updateTaskStatus(taskId, { status: newStatus, remarks: remarks || "" });
                        await drawTaskList(handoverId, user);
                    } catch (err) {
                        alert("Failed to update status");
                        sel.disabled = false;
                    }
                });
                sel.addEventListener('focus', function() {
                    this.setAttribute('data-previous', this.value);
                });
            });

            // Remarks button handler
            slot.querySelectorAll(".task-remarks-btn").forEach((btn) => {
                btn.addEventListener("click", async () => {
                    const taskId = btn.dataset.taskId;
                    const task = tasks.find(t => t.id === parseInt(taskId));
                    const remarks = prompt(`Add remarks for task "${task?.title || taskId}":`, task?.remarks || "");
                    if (remarks === null) return;
                    
                    try {
                        await API.updateTask(taskId, {
                            ...task,
                            remarks: remarks || ""
                        });
                        await drawTaskList(handoverId, user);
                    } catch (err) {
                        alert("Failed to update remarks");
                    }
                });
            });

            slot.querySelectorAll(".task-delete-btn").forEach((btn) => {
                btn.addEventListener("click", async () => {
                    if (window.confirm("Delete this task?")) {
                        await API.deleteTask(btn.dataset.taskId);
                        await drawTaskList(handoverId, user);
                    }
                });
            });
        }

